# Neon Postgres pooled connection string
DATABASE_URL=postgres://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require

# Telegram bot (reuse @JHbirthdayBot if you already set one up)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google AI Studio API key — free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Leave empty to disable the login wall. Set any value to require that
# password at /login before viewing or editing holdings.
APP_PASSWORD=

# Reserved for future use.
CRON_SECRET=
